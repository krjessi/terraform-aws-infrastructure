<mxfile host="app.diagrams.net">
  <diagram name="AWS Architecture">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" page="1" pageScale="1" pageWidth="1654" pageHeight="1169">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="vpc" value="Production VPC&#10;10.0.0.0/16"
          style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;"
          vertex="1" parent="1">
          <mxGeometry x="150" y="120" width="1200" height="700" as="geometry"/>
        </mxCell>

        <mxCell id="internet" value="🌍 Internet"
          style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="20" width="180" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="igw" value="Internet Gateway"
          style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="80" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="puba" value="Public Subnet A" style="rounded=1;" vertex="1" parent="vpc">
          <mxGeometry x="70" y="70" width="250" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="pubb" value="Public Subnet B" style="rounded=1;" vertex="1" parent="vpc">
          <mxGeometry x="880" y="70" width="250" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="alb" value="Application Load Balancer" style="rounded=1;" vertex="1" parent="vpc">
          <mxGeometry x="430" y="95" width="340" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="appa" value="Private App Subnet A" style="rounded=1;" vertex="1" parent="vpc">
          <mxGeometry x="120" y="260" width="320" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="appb" value="Private App Subnet B" style="rounded=1;" vertex="1" parent="vpc">
          <mxGeometry x="760" y="260" width="320" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="ec2a" value="EC2" style="rounded=1;" vertex="1" parent="vpc">
          <mxGeometry x="220" y="310" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="ec2b" value="EC2" style="rounded=1;" vertex="1" parent="vpc">
          <mxGeometry x="860" y="310" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="dba" value="Private DB Subnet A" style="rounded=1;" vertex="1" parent="vpc">
          <mxGeometry x="120" y="500" width="320" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="dbb" value="Private DB Subnet B" style="rounded=1;" vertex="1" parent="vpc">
          <mxGeometry x="760" y="500" width="320" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="rds" value="PostgreSQL RDS" style="rounded=1;" vertex="1" parent="vpc">
          <mxGeometry x="470" y="545" width="220" height="60" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
